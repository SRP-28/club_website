# ============================================================
# Email Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# The Gmail address that sends the contact form emails.
EMAIL_USER=your_email@gmail.com

# Gmail App Password (NOT your account password).
# Steps to generate one:
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to Google Account > Security > App Passwords.
# 3. Select "Mail" and generate a password.
# 4. Paste the 16-character password here (spaces are OK).
EMAIL_PASS=xxxx xxxx xxxx xxxx

# The email address that will RECEIVE the contact form submissions.
EMAIL_TO=your_club_email@example.com

# Port the backend server will listen on.
PORT=5001
